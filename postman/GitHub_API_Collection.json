{
  "info": {
    "name": "GitHub API Test Collection",
    "description": "Production-grade API test collection for GitHub REST API.\nCovers: Auth, Users, Repos, Search, and Negative scenarios.\nAuthor: Sourabh Sagar | github.com/sgr111",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.github.com",
      "type": "string"
    },
    {
      "key": "github_token",
      "value": "{{GITHUB_TOKEN}}",
      "type": "string"
    },
    {
      "key": "known_user",
      "value": "torvalds",
      "type": "string"
    },
    {
      "key": "known_repo_owner",
      "value": "psf",
      "type": "string"
    },
    {
      "key": "known_repo_name",
      "value": "requests",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Auth & Rate Limit",
      "item": [
        {
          "name": "GET /rate_limit - Check API Quota",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": { "raw": "{{base_url}}/rate_limit", "host": ["{{base_url}}"], "path": ["rate_limit"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is under 3000ms', function() {",
                  "  pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test('Rate limit has core resource', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.resources).to.have.property('core');",
                  "});",
                  "",
                  "pm.test('Authenticated limit is at least 5000', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.rate.limit).to.be.at.least(5000);",
                  "});",
                  "",
                  "pm.test('Remaining requests is non-negative', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.rate.remaining).to.be.at.least(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /user - Authenticated User Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": { "raw": "{{base_url}}/user", "host": ["{{base_url}}"], "path": ["user"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has login field', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('login');",
                  "  pm.expect(json.login).to.not.be.empty;",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function() {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "// Save username for use in later requests",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('auth_user_login', json.login);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Users",
      "item": [
        {
          "name": "GET /users/{username} - Known User Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": {
              "raw": "{{base_url}}/users/{{known_user}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{known_user}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Login matches requested username', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.login).to.equal(pm.collectionVariables.get('known_user'));",
                  "});",
                  "",
                  "pm.test('User type is User', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.type).to.equal('User');",
                  "});",
                  "",
                  "pm.test('User has at least 1 public repo', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.public_repos).to.be.at.least(1);",
                  "});",
                  "",
                  "pm.test('Response time is under 3000ms', function() {",
                  "  pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /users/{username}/repos - User Repos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": {
              "raw": "{{base_url}}/users/{{known_user}}/repos?per_page=5",
              "host": ["{{base_url}}"],
              "path": ["users", "{{known_user}}", "repos"],
              "query": [{ "key": "per_page", "value": "5" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('per_page=5 returns at most 5 repos', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.length).to.be.at.most(5);",
                  "});",
                  "",
                  "pm.test('Each repo has a name field', function() {",
                  "  var json = pm.response.json();",
                  "  json.forEach(function(repo) {",
                  "    pm.expect(repo).to.have.property('name');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /users/{username}/followers - User Followers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": {
              "raw": "{{base_url}}/users/{{known_user}}/followers?per_page=5",
              "host": ["{{base_url}}"],
              "path": ["users", "{{known_user}}", "followers"],
              "query": [{ "key": "per_page", "value": "5" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each follower has login field', function() {",
                  "  var json = pm.response.json();",
                  "  json.forEach(function(follower) {",
                  "    pm.expect(follower).to.have.property('login');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Repos",
      "item": [
        {
          "name": "GET /repos/{owner}/{repo} - Known Repo",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": {
              "raw": "{{base_url}}/repos/{{known_repo_owner}}/{{known_repo_name}}",
              "host": ["{{base_url}}"],
              "path": ["repos", "{{known_repo_owner}}", "{{known_repo_name}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Repo name matches request', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.name).to.equal(pm.collectionVariables.get('known_repo_name'));",
                  "});",
                  "",
                  "pm.test('Repo is not private', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.private).to.equal(false);",
                  "});",
                  "",
                  "pm.test('Repo has more than 1000 stars', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.stargazers_count).to.be.above(1000);",
                  "});",
                  "",
                  "pm.test('Default branch exists', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.default_branch).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /repos/{owner}/{repo}/commits - Repo Commits",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": {
              "raw": "{{base_url}}/repos/{{known_repo_owner}}/{{known_repo_name}}/commits?per_page=5",
              "host": ["{{base_url}}"],
              "path": ["repos", "{{known_repo_owner}}", "{{known_repo_name}}", "commits"],
              "query": [{ "key": "per_page", "value": "5" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each commit has sha of 40 characters', function() {",
                  "  var json = pm.response.json();",
                  "  json.forEach(function(commit) {",
                  "    pm.expect(commit.sha).to.have.lengthOf(40);",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /repos/{owner}/{repo}/languages - Repo Languages",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": {
              "raw": "{{base_url}}/repos/{{known_repo_owner}}/{{known_repo_name}}/languages",
              "host": ["{{base_url}}"],
              "path": ["repos", "{{known_repo_owner}}", "{{known_repo_name}}", "languages"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Python is listed as a language', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('Python');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Search",
      "item": [
        {
          "name": "GET /search/repositories - Search Repos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": {
              "raw": "{{base_url}}/search/repositories?q=fastapi&sort=stars&order=desc&per_page=5",
              "host": ["{{base_url}}"],
              "path": ["search", "repositories"],
              "query": [
                { "key": "q", "value": "fastapi" },
                { "key": "sort", "value": "stars" },
                { "key": "order", "value": "desc" },
                { "key": "per_page", "value": "5" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('total_count is greater than 0', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.total_count).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Items list is not empty', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.items.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Results sorted by stars descending', function() {",
                  "  var items = pm.response.json().items;",
                  "  for (var i = 0; i < items.length - 1; i++) {",
                  "    pm.expect(items[i].stargazers_count).to.be.at.least(items[i+1].stargazers_count);",
                  "  }",
                  "});",
                  "",
                  "pm.test('Response time is under 5000ms', function() {",
                  "  pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /search/users - Search Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" },
              { "key": "X-GitHub-Api-Version", "value": "2022-11-28" }
            ],
            "url": {
              "raw": "{{base_url}}/search/users?q=torvalds&per_page=5",
              "host": ["{{base_url}}"],
              "path": ["search", "users"],
              "query": [
                { "key": "q", "value": "torvalds" },
                { "key": "per_page", "value": "5" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('total_count is greater than 0', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.total_count).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Each user item has login field', function() {",
                  "  var json = pm.response.json();",
                  "  json.items.forEach(function(user) {",
                  "    pm.expect(user).to.have.property('login');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Negative Tests",
      "item": [
        {
          "name": "GET /users/{invalid} - Non-existent User Returns 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" }
            ],
            "url": {
              "raw": "{{base_url}}/users/this-user-does-not-exist-xyz999abc",
              "host": ["{{base_url}}"],
              "path": ["users", "this-user-does-not-exist-xyz999abc"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404 for non-existent user', function() {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Error message says Not Found', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.message).to.equal('Not Found');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /repos/{invalid} - Non-existent Repo Returns 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{GITHUB_TOKEN}}" },
              { "key": "Accept", "value": "application/vnd.github+json" }
            ],
            "url": {
              "raw": "{{base_url}}/repos/torvalds/this-repo-does-not-exist-xyz999",
              "host": ["{{base_url}}"],
              "path": ["repos", "torvalds", "this-repo-does-not-exist-xyz999"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404 for non-existent repo', function() {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Response has message field', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /user - Invalid Token Returns 401",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer this_is_a_completely_invalid_token_xyz123" },
              { "key": "Accept", "value": "application/vnd.github+json" }
            ],
            "url": {
              "raw": "{{base_url}}/user",
              "host": ["{{base_url}}"],
              "path": ["user"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 for invalid token', function() {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Response has error message', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
